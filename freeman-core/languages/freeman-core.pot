#: src/Core/Feature_Flags.php:99
msgid "Settings import"
msgstr ""

#: src/Core/Feature_Flags.php:100
msgid "Adds the Import form under Freeman → Tools. Export, backup listing and restore stay available regardless, so a settings rollback still works after disabling import."
msgstr ""

#: src/Core/Feature_Flags.php:107
msgid "Variation Swatches — card image swap"
msgstr ""

#: src/Core/Feature_Flags.php:108
msgid "On shop / archive pages, clicking a swatch swaps the product card image to the matching variation image — no navigation, no Quick View."
msgstr ""

#: src/Core/Feature_Flags.php:115
msgid "Variation Swatches — image swatches"
msgstr ""

#: src/Core/Feature_Flags.php:116
msgid "Lets each attribute term use an uploaded image instead of a colour; adds the upload UI to the term-edit screen and renders image thumbnails in the shop picker and PDP buy box. Image wins over colour when both are set."
msgstr ""

#: src/Core/Feature_Flags.php:123
msgid "Variation Swatches — hover tooltip"
msgstr ""

#: src/Core/Feature_Flags.php:124
msgid "Shows a CSS hover tooltip on colour and image swatches; the text defaults to the term name and is overridable per term from the term-edit screen."
msgstr ""

#: src/Core/Feature_Flags.php:131
msgid "Variation Swatches — auto colour sampler"
msgstr ""

#: src/Core/Feature_Flags.php:132
msgid "Samples each variation image to a representative hex (cached as post-meta, refreshed on save, pre-warmed via WP-Cron) and uses it as the swatch colour when no manual term colour is set. One toggle drives both the sampler pipeline and the render-path fallback."
msgstr ""

#: src/Core/Feature_Flags.php:139
msgid "Sliders — advanced controls"
msgstr ""

#: src/Core/Feature_Flags.php:140
msgid "Adds autoplay, loop and dots / progress-indicator controls to the Category Slider and Product Slider Elementor widgets (on Product Slider, only when display mode is \"slider\")."
msgstr ""

#: src/Core/Feature_Flags.php:147
msgid "Cheapest Default Variation — strategy selector"
msgstr ""

#: src/Core/Feature_Flags.php:148
msgid "Adds a \"cheapest / first in stock\" choice (global setting, per-product meta override and a filter) for which variation gets pre-selected. Off: the original hardcoded \"cheapest\" behaviour."
msgstr ""

#: src/Core/Feature_Flags.php:155
msgid "Infinite Scroll — trigger modes"
msgstr ""

#: src/Core/Feature_Flags.php:156
msgid "Adds trigger-mode (observer / load-more button / hybrid), history-mode and container-selector settings, the wrapper render path and its hooks. Off: the original auto-observer behaviour."
msgstr ""

#: src/Core/Feature_Flags.php:163
msgid "Restock Notify — CSV export"
msgstr ""

#: src/Core/Feature_Flags.php:164
msgid "Adds an \"Export Subscribers\" submenu under the Restock Notify menu that streams the full subscriber table as CSV. (The GDPR exporter / eraser is always on — it is a platform contract, not gated by this flag.)"
msgstr ""

#: src/Core/Feature_Flags.php:171
msgid "Quick View — storefront"
msgstr ""

#: src/Core/Feature_Flags.php:172
msgid "Adds the quick-view icon to product cards and the slide-in drawer (image, price, short description, add-to-cart, product-page link) backed by a public AJAX endpoint. Off: no storefront output and no endpoint."
msgstr ""

#: src/Core/Feature_Flags.php:179
msgid "Variation Swatches — WPC Bundles / FBT compatibility"
msgstr ""

#: src/Core/Feature_Flags.php:180
msgid "Forwards all buy-box form fields to WooCommerce's add-to-cart endpoint so WPC Product Bundles and WPC Frequently-Bought-Together hidden inputs reach the cart; exposes a JS flag for the runtime."
msgstr ""

